# Client-side only. Copy to .env or .env.local in this folder.
# Anything secret or server-only belongs in ../backend/.env (never VITE_*).

# Local dev: point at your API. Production Vercel builds auto-detect Render when unset.
VITE_API_BASE_URL=http://127.0.0.1:8080
# Production (set in Vercel env or rely on runtime fallback on rfincare.com / Vercel):
# VITE_API_BASE_URL=https://rfincare.onrender.com
# OAuth callback route in SPA: /oauth/callback (set OAUTH_FRONTEND_CALLBACK in backend/.env)
VITE_GA_MEASUREMENT_ID=

# Used by public/setup-demo-users.html (Supabase project URL only).
VITE_SUPABASE_URL=
